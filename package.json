  "scripts": {
    "watch": "docker compose -f docker-compose.dev.yml up -d & cross-env NODE_ENV=development webpack watch -c build/webpack.config.js",
    "build": "rimraf dist/server & rimraf dist/web & cross-env NODE_ENV=development webpack -c build/webpack.config.js",
    "build:prod": "rimraf dist/server & rimraf dist/web & cross-env NODE_ENV=production webpack -c build/webpack.config.js",
    "test": "mocha -r ts-node/register -r tsconfig-paths/register 'test/**/*.test.ts'",
    "deploy": "build",
    "migrate": "knex --knexfile dist/knexfile.js --migrations-directory ../migrations"
  },
