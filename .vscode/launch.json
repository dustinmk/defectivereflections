    "version": "0.2.0",
    "configurations": [
        {
            "name": "ExpressJS",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/dist/server/server/index.js",
            "cwd": "${workspaceFolder}/dist",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "outFiles": [
                "${workspaceFolder}/dist/server/**/*.(m|c|)js",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeArgs": [
                "-r", "tsconfig-paths/register"
            ],
            "preLaunchTask": "npm build"
        },
        {
            "name": "Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}"
        },
